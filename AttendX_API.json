      "name": "Auth",
      "description": "Authentication endpoints",
      "item": [
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Student\",\n  \"email\": \"student@attendx.com\",\n  \"phone\": \"+250788111222\",\n  \"password\": \"Student@123\",\n  \"role\": \"student\",\n  \"regNumber\": \"2024/CS/001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has token and user', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.token).to.be.a('string');",
                  "    pm.expect(jsonData.data.user.id).to.be.a('string');",
                  "    pm.environment.set('accessToken', jsonData.data.token);",
                  "    pm.environment.set('userId', jsonData.data.user.id);",
                  "    pm.environment.set('userRole', jsonData.data.user.role);",
                  "});"
                ]
              }
            }
          ]
        },
