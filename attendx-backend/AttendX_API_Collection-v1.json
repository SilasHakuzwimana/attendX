{
  "info": {
    "name": "AttendX API - Attendance Flow",
    "description": "Smart Hybrid Attendance Management System\n\nWorkflow:\n1. Register Users (Student, Lecturer, Admin)\n2. Student pre-checks in with GPS location\n3. Lecturer starts attendance session\n4. System validates attendance via geofence\n5. View history, analytics & manage settings",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "2.1.0"
  },
  "item": [
    {
      "name": "1. Auth (Register & Login)",
      "description": "Step 1: Register users by role, then login",
      "item": [
        {
          "name": "Register Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Registration successful', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success) {",
                  "    pm.environment.set('studentToken', jsonData.data.token);",
                  "    pm.environment.set('studentId', jsonData.data.user.id);",
                  "    pm.environment.set('studentRegNumber', '2024/CS/001');",
                  "    console.log('Student registered:', jsonData.data.user.fullName);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Alice Muwanguzi\",\n  \"email\": \"alice.student@attendx.com\",\n  \"phone\": \"+256700111222\",\n  \"password\": \"Student@123\",\n  \"role\": \"student\",\n  \"regNumber\": \"2024/CS/001\"\n}"
