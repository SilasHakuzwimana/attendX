    {
      "name": "4. Lecturer Starts Attendance Session",
      "description": "Step 3: Lecturer creates session → System validates → Notifications sent",
      "item": [
        {
          "name": "Start Attendance Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success) {",
                  "    pm.environment.set('sessionId', jsonData.data.session.id);",
                  "    pm.environment.set('sessionCode', jsonData.data.session.sessionCode);",
                  "    console.log('Session Code:', jsonData.data.session.sessionCode);",
                  "    console.log('Present:', jsonData.data.attendanceSummary.present);",
                  "    console.log('Absent:', jsonData.data.attendanceSummary.absent);",
                  "    console.log('Confirmations sent:', jsonData.data.notifications.confirmations);",
                  "    console.log('Missed alerts:', jsonData.data.notifications.missedAlerts);",
                  "    console.log('Urgent warnings:', jsonData.data.notifications.urgentWarnings);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": \"{{courseId}}\",\n  \"classroomId\": \"{{classroomId}}\",\n  \"durationMinutes\": 90\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions"]
            }
          }
        },
        {
          "name": "Get Session Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions", "{{sessionId}}"]
            }
          }
        },
        {
          "name": "View Session Attendance List",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}/attendance",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions", "{{sessionId}}", "attendance"]
            }
          }
        },
        {
          "name": "Close Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sessions/{{sessionId}}/close",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sessions", "{{sessionId}}", "close"]
            }
          }
        }
      ]
    },
